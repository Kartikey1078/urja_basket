# --- Admin UI session (this Next app only) ---
# Password operators enter at /login (min 8 chars recommended).
ADMIN_APP_PASSWORD=change-me-admin-ui-password

# JWT for httpOnly session cookie (min 32 characters).
ADMIN_SESSION_SECRET=change-me-use-a-long-random-secret-at-least-32-chars

# --- Upstream Express API ---
# Must match server ADMIN_API_KEY (min 8 chars). Used only server-side in /api/backend proxy.
ADMIN_API_KEY=change-me-use-long-random-secret

# Base URL of the Urja Basket API (no trailing slash).
INTERNAL_API_URL=http://127.0.0.1:4000

# Optional fallback for INTERNAL_API_URL when unset.
NEXT_PUBLIC_API_URL=http://localhost:4000
