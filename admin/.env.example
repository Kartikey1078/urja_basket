# --- Admin UI session (this Next app only) ---
ADMIN_APP_PASSWORD=
# JWT for httpOnly session cookie (min 32 characters)
ADMIN_SESSION_SECRET=

# --- Upstream Express API ---
# Must match server ADMIN_API_KEY (min 8 chars). Server-side only (BFF proxy).
ADMIN_API_KEY=

# Express API URL (no trailing slash).
# Railway: public URL or private networking URL of the API service
# Example: https://your-api-service.up.railway.app
INTERNAL_API_URL=

# Optional fallback if INTERNAL_API_URL is unset
NEXT_PUBLIC_API_URL=

# Railway sets PORT automatically for `next start` — do not hardcode in production.
