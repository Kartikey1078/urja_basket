# =============================================================================
# Urja Basket API — Environment variables (server/)
# Copy to server/.env for local dev or production on EC2.
# Never commit .env with real secrets.
# =============================================================================

# --- Runtime ---
NODE_ENV=production
# API listen port (PM2 + Nginx proxy to this). Default: 4000
PORT=4000

# Comma-separated allowed browser origins (storefront + admin public URLs)
# Example: https://shop.yourdomain.com,https://admin.yourdomain.com
CORS_ORIGIN=

# --- Admin API (Bearer for /api/v1/admin/*) ---
# Min 8 characters; must match admin service ADMIN_API_KEY
ADMIN_API_KEY=

# --- MySQL (choose ONE approach) ---

# Option A — Single connection URL (RDS or external MySQL):
# MYSQL_URL=mysql://user:password@host:3306/urja_basket

# Option B — Standard variables (recommended for EC2 + RDS):
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=urja_basket

# Optional: enable TLS for RDS / external MySQL
# DB_SSL=true
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_POOL_LIMIT=10

# --- Clerk (same app as storefront) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Telegram admin alerts (optional) ---
# Create bot via @BotFather, then get chat id from getUpdates after /start
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_ALERTS_ENABLED=false
# Optional link in alert messages (no trailing slash)
ADMIN_PUBLIC_URL=

# --- Optional (not required today) ---
# REDIS_URL=
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
