# =============================================================================
# Urja Basket API — Environment variables (server/)
# Copy to server/.env for local dev. On Railway, set these in the service Variables tab.
# Never commit .env with real secrets.
# =============================================================================

# --- Runtime ---
NODE_ENV=production
# Railway sets PORT automatically — do not hardcode in production
PORT=4000

# Comma-separated allowed browser origins (storefront + admin public URLs)
# Example: https://urja-basket.up.railway.app,https://urja-admin.up.railway.app
CORS_ORIGIN=

# --- Admin API (Bearer for /api/v1/admin/*) ---
# Min 8 characters; must match admin service ADMIN_API_KEY
ADMIN_API_KEY=

# --- MySQL (choose ONE approach) ---

# Option A — Railway MySQL plugin (recommended; reference variables from MySQL service):
# MYSQLHOST=${{MySQL.MYSQLHOST}}
# MYSQLPORT=${{MySQL.MYSQLPORT}}
# MYSQLUSER=${{MySQL.MYSQLUSER}}
# MYSQLPASSWORD=${{MySQL.MYSQLPASSWORD}}
# MYSQLDATABASE=${{MySQL.MYSQLDATABASE}}

# Option B — Single connection URL:
# MYSQL_URL=mysql://user:password@host:port/database

# Option C — Standard names (local Docker / phpMyAdmin / external MySQL):
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=urja_basket

# Optional: enable TLS for external MySQL (set true for public DB endpoints)
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=false
# DB_POOL_LIMIT=10

# --- Clerk (same app as storefront) ---
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# --- Razorpay ---
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# --- Optional (not required today) ---
# REDIS_URL=
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=
