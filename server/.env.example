# Copy to .env (never commit .env).
NODE_ENV=development
PORT=4000

# Comma-separated browser origins allowed for CORS + Clerk session verification
CORS_ORIGIN=http://localhost:3000

# Admin API (CRUD under /api/v1/admin/*). Min 8 characters; must match `admin/.env.local` ADMIN_API_KEY (BFF proxy).
ADMIN_API_KEY=change-me-use-long-random-secret


# MySQL (phpMyAdmin / managed instance) — used by mysql2 pool in src/database
DB_HOST=localhost
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=urja_basket

# Redis (sessions, cache, rate limits)
REDIS_URL="redis://localhost:6379"

# JWT / auth (set strong secrets in production)
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# Cloudinary (product images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Clerk (same instance as frontend). Required for GET /api/me
CLERK_SECRET_KEY=sk_test_y46ZAcpabIjzoU00Dt2HaOvhjvZFX6jbzWt9krbDAT
CLERK_PUBLISHABLE_KEY=pk_test_bW9kZXJuLXdyZW4tNDYuY2xlcmsuYWNjb3VudHMuZGV2JA

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
