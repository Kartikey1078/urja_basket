# Nginx reverse proxy for Urja Basket API (EC2, no Docker)
# Copy to /etc/nginx/sites-available/urja-api and symlink into sites-enabled.
#
# Replace api.example.com with your domain or use the EC2 public IP for testing.

upstream urja_api {
    server 127.0.0.1:4000;
    keepalive 32;
}

server {
    listen 80;
    server_name api.example.com;

    client_max_body_size 10m;

    location / {
        proxy_pass http://urja_api;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Connection "";
    }

    location /api/v1/health {
        proxy_pass http://urja_api;
        access_log off;
    }
}

# After certbot:
# sudo certbot --nginx -d api.example.com
