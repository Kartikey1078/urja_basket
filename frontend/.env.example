# Clerk (same app as server/.env). Secret is server-only — never prefix with NEXT_PUBLIC_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Public API base (browser + server components). No trailing slash.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Standalone admin console (used only for /admin → redirect). No trailing slash.
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# Razorpay checkout (public key)
NEXT_PUBLIC_RAZORPAY_KEY_ID=
