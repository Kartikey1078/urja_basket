# Clerk (same app as server). Secret is server-only — never prefix with NEXT_PUBLIC_
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Express API public URL (no trailing slash). Required for production builds.
# Local dev: http://localhost:4000
# Vercel / production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=

# Standalone admin console URL (for /admin redirect). No trailing slash.
NEXT_PUBLIC_ADMIN_URL=

# Razorpay checkout (public key — must match server RAZORPAY_KEY_ID)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# Local dev only — Vercel sets PORT automatically; do not override on Vercel.
PORT=3000
